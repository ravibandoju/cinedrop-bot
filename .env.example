# ============================================================================
# INSTAGRAM DAILY MOVIE POST BOT - ENVIRONMENT VARIABLES
# ============================================================================
# Copy this file to .env and fill in your actual API keys
# Never commit your .env file to version control!

# TMDb API Key
# Get it from: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# Groq API Key (free tier, no credit card needed)
# Get it from: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Instagram Graph API - Access Token
# Get it from: https://developers.facebook.com/
# Must have Instagram Business Account connected
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token_here

# Instagram Business Account ID
# Get it from: https://developers.facebook.com/ -> Settings -> Business Accounts
INSTAGRAM_ACCOUNT_ID=your_instagram_account_id_here

# GitHub Token (for committing posted_movies.json back to repo)
# Create from: https://github.com/settings/tokens
# Requires 'repo' scope for full control of private repositories
GH_TOKEN=your_github_token_here
